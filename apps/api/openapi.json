          }
        }
      }
    },
    "/api/pools": {
      "get": {
        "tags": ["Fleet"],
        "summary": "List load generator pools",
        "operationId": "listPools",
        "responses": {
          "200": {
            "description": "List of pools",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pools": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Pool" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Fleet"],
        "summary": "Create a load generator pool",
        "operationId": "createPool",
        "requestBody": {
          "required": true,
